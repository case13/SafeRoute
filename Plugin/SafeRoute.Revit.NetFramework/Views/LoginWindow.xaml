<Window x:Class="SafeRoute.Revit.NetFramework.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SafeRoute - Login"
        Width="460" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- BaseUrl -->
            <RowDefinition Height="12"/>
            <!-- Spacer -->
            <RowDefinition Height="Auto"/>
            <!-- Email -->
            <RowDefinition Height="12"/>
            <!-- Spacer -->
            <RowDefinition Height="Auto"/>
            <!-- Senha -->
            <RowDefinition Height="12"/>
            <!-- Spacer -->
            <RowDefinition Height="Auto"/>
            <!-- Status -->
            <RowDefinition Height="*"/>
            <!-- Filler -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="BaseUrl"/>
        <TextBox x:Name="BaseUrlTextBox" Grid.Row="0" Grid.Column="1" />

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Email"/>
        <TextBox x:Name="EmailTextBox" Grid.Row="2" Grid.Column="1" />

        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Senha"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="4" Grid.Column="1" />

        <TextBlock x:Name="StatusText"
                   Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                   Foreground="DarkRed"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="90" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button x:Name="LoginButton" Content="Entrar" Width="90" Click="Login_Click"/>
        </StackPanel>
    </Grid>
</Window>
