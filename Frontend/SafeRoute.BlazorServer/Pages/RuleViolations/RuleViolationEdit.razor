@using MudBlazor
@using SafeRoute.BlazorServer.Components.Forms
@using SafeRoute.BlazorServer.ViewModels.Interfaces
@using SafeRoute.Shared.Dtos.Rules
@inject IRuleViolationViewModel Vm

@code {
    [Parameter] public int RuleViolationId { get; set; }
}

<FormBaseDialog TModel="UpdateRuleViolationDto"
                Subtitle="Editar Violação"
                SaveButtonText="Gravar"
                Model="Vm.Edit"
                OnCancel="Cancel"
                OnSave="SaveAsync">

    <ChildContent Context="m">
        <MudTextField T="string"
                      Label="Mensagem"
                      Variant="Variant.Outlined"
                      @bind-Value="m.Message"
                      For="@(() => m.Message)"
                      Required="true"
                      FullWidth="true" />

        <MudSelect T="SafeRoute.Shared.Enums.Rules.RuleSeverityEnum"
                   Label="Severidade"
                   Variant="Variant.Outlined"
                   @bind-Value="m.Severity"
                   Required="true"
                   FullWidth="true">
            @foreach (var val in Enum.GetValues<SafeRoute.Shared.Enums.Rules.RuleSeverityEnum>())
            {
                <MudSelectItem Value="val">@val</MudSelectItem>
            }
        </MudSelect>

        <MudSwitch T="bool"
                   Color="Color.Primary"
                   @bind-Checked="m.IsActive">
            Ativo
        </MudSwitch>
    </ChildContent>

</FormBaseDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        if (RuleViolationId > 0)
            await Vm.LoadByIdAsync(RuleViolationId);
    }

    private Task Cancel()
    {
        MudDialog.Cancel();
        return Task.CompletedTask;
    }

    private async Task<bool> SaveAsync()
    {
        var ok = await Vm.SaveEditAsync();
        if (ok)
            MudDialog.Close(DialogResult.Ok(true));

        return ok;
    }
}
