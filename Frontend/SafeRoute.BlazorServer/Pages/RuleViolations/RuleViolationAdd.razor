@using MudBlazor
@using SafeRoute.BlazorServer.Components.Forms
@using SafeRoute.BlazorServer.ViewModels.Interfaces
@using SafeRoute.Shared.Dtos.Rules
@inject IRuleViolationViewModel Vm

<FormBaseDialog TModel="CreateRuleViolationDto"
                Subtitle="Nova Violação"
                SaveButtonText="Gravar"
                Model="Vm.New"
                OnCancel="Cancel"
                OnSave="SaveAsync">

    <ChildContent Context="m">
        <MudTextField T="string"
                      Label="Elemento (ExternalId)"
                      Variant="Variant.Outlined"
                      @bind-Value="m.ElementExternalId"
                      For="@(() => m.ElementExternalId)"
                      Required="true"
                      FullWidth="true" />

        <MudSelect T="SafeRoute.Shared.Enums.Elements.ElementTypeEnum"
                   Label="Tipo do Elemento"
                   Variant="Variant.Outlined"
                   @bind-Value="m.ElementType"
                   Required="true"
                   FullWidth="true">
            @foreach (var val in Enum.GetValues<SafeRoute.Shared.Enums.Elements.ElementTypeEnum>())
            {
                <MudSelectItem Value="val">@val</MudSelectItem>
            }
        </MudSelect>

        <MudTextField T="string"
                      Label="Regra (Code)"
                      Variant="Variant.Outlined"
                      @bind-Value="m.RuleCode"
                      For="@(() => m.RuleCode)"
                      Required="true"
                      FullWidth="true" />

        <MudTextField T="string"
                      Label="Mensagem"
                      Variant="Variant.Outlined"
                      @bind-Value="m.Message"
                      For="@(() => m.Message)"
                      Required="true"
                      FullWidth="true" />

        <MudSelect T="SafeRoute.Shared.Enums.Rules.RuleSeverityEnum"
                   Label="Severidade"
                   Variant="Variant.Outlined"
                   @bind-Value="m.Severity"
                   Required="true"
                   FullWidth="true">
            @foreach (var val in Enum.GetValues<SafeRoute.Shared.Enums.Rules.RuleSeverityEnum>())
            {
                <MudSelectItem Value="val">@val</MudSelectItem>
            }
        </MudSelect>
    </ChildContent>

</FormBaseDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;

    private Task Cancel()
    {
        MudDialog.Cancel();
        return Task.CompletedTask;
    }

    private async Task<bool> SaveAsync()
    {
        var ok = await Vm.CreateAsync();
        if (ok)
            MudDialog.Close(DialogResult.Ok(true));

        return ok;
    }
}
