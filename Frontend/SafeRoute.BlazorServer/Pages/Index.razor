@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SafeRoute.BlazorServer.Components
@attribute [Authorize]
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
    <MudStack Direction="Row">

        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            <MudText Typo="Typo.h4">Dashboard</MudText>
            <MudText Typo="Typo.body1">Bem-vindo ao SafeRoute</MudText>

            <AuthorizeView>
                <Authorized>
                    @if (IsHome)
                    {
                        <HomeMenu />
                    }
                </Authorized>
            </AuthorizeView>
        </MudContainer>

    </MudStack>
</MudContainer>

@code {
    private bool IsHome =>
        Nav.Uri.EndsWith("/", StringComparison.OrdinalIgnoreCase) ||
        Nav.Uri.EndsWith("/index", StringComparison.OrdinalIgnoreCase);
}
