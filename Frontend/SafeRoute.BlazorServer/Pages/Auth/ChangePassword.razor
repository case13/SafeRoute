@page "/auth/change-password"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using SafeRoute.BlazorServer.ViewModels.Interfaces
@inject IAuthViewModel Vm
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Small"
              Class="d-flex align-center justify-center"
              Style="height:calc(100vh - 64px);">

    <MudPaper Elevation="10"
              Class="pa-6"
              Style="width:100%; max-width:520px; border-radius:12px;">

        <MudStack Spacing="3">

            <MudText Typo="Typo.h5" Align="Align.Center">
                Alterar Senha
            </MudText>

            <MudDivider />

            <MudTextField Label="Senha atual"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          @bind-Value="Vm.CurrentPassword"
                          FullWidth />

            <MudTextField Label="Nova senha"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          @bind-Value="Vm.NewPassword"
                          FullWidth />

            <MudTextField Label="Confirmar nova senha"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          @bind-Value="Vm.ConfirmNewPassword"
                          FullWidth />

            @if (!string.IsNullOrWhiteSpace(Vm.ChangePasswordError))
            {
                <MudText Color="Color.Error" Align="Align.Center">
                    @Vm.ChangePasswordError
                </MudText>
            }

            @if (!string.IsNullOrWhiteSpace(Vm.ChangePasswordSuccess))
            {
                <MudText Color="Color.Success" Align="Align.Center">
                    @Vm.ChangePasswordSuccess
                </MudText>
            }

            <MudStack Direction="Row" Spacing="2" Class="mt-2">

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           FullWidth
                           OnClick="Cancel">
                    Cancelar
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="Vm.IsBusy"
                           FullWidth
                           OnClick="ChangeAsync">
                    Salvar
                </MudButton>

            </MudStack>

        </MudStack>

    </MudPaper>
</MudContainer>

@code {

    private async Task ChangeAsync()
    {
        await Vm.ChangePasswordAsync();
    }

    private void Cancel()
    {
        Vm.ClearChangePassword();
        Nav.NavigateTo("/");
    }
}