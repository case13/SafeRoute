@page "/set-password"
@attribute [AllowAnonymous]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using SafeRoute.BlazorServer.Services.Interfaces
@using SafeRoute.Shared.Dtos.Auth
@inject NavigationManager Nav
@inject IAuthHttpService AuthHttp

<MudContainer MaxWidth="MaxWidth.Small"
              Class="d-flex align-center justify-center"
              Style="height:100vh;">

    <MudPaper Elevation="10"
              Class="pa-6"
              Style="width:100%; max-width:420px; border-radius:12px;">

        <MudStack Spacing="4">

            <MudText Typo="Typo.h5" Align="Align.Center">Definir Senha</MudText>
            <MudDivider />

            <MudTextField Label="Email"
                          Variant="Variant.Outlined"
                          Value="@Email"
                          Disabled="true"
                          FullWidth />

            <MudTextField Label="Nova senha"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          @bind-Value="Password"
                          FullWidth />

            <MudTextField Label="Confirmar senha"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          @bind-Value="ConfirmPassword"
                          FullWidth />

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <MudText Typo="Typo.body2" Color="Color.Error" Align="Align.Center">
                    @Error
                </MudText>
            }

            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       Size="Size.Large"
                       Disabled="IsBusy"
                       FullWidth
                       OnClick="SaveAsync">
                Salvar
            </MudButton>

        </MudStack>

    </MudPaper>
</MudContainer>

@code {
    private string Email = string.Empty;
    private string Password = string.Empty;
    private string ConfirmPassword = string.Empty;
    private string Error = string.Empty;
    private bool IsBusy;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("email", out var email))
            Email = email.ToString();
    }

    private async Task SaveAsync()
    {
        Error = string.Empty;
        IsBusy = true;

        try
        {
            if (string.IsNullOrWhiteSpace(Email))
            {
                Error = "Email inválido.";
                return;
            }

            if (string.IsNullOrWhiteSpace(Password) || string.IsNullOrWhiteSpace(ConfirmPassword))
            {
                Error = "Informe e confirme a senha.";
                return;
            }

            if (Password != ConfirmPassword)
            {
                Error = "As senhas não conferem.";
                return;
            }

            var ok = await AuthHttp.SetPasswordAsync(new SetPasswordDto
            {
                Email = Email,
                Password = Password,
                ConfirmPassword = ConfirmPassword
            });

            if (!ok)
            {
                Error = "Não foi possível definir a senha. Tente novamente.";
                return;
            }

            Nav.NavigateTo("/login", forceLoad: true);
        }
        finally
        {
            IsBusy = false;
        }
    }
}