@using MudBlazor
@inject NavigationManager Nav

<MudPaper Class="pa-3 mb-3"
          Elevation="1"
          Style="@($"background-color:#f9f9f9; border-radius:10px; margin:{Margin};")">

    <MudStack Row="true"
              AlignItems="AlignItems.Center"
              Justify="Justify.SpaceBetween"
              Spacing="2">

        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

            @if (ShowHome)
            {
                <MudFab StartIcon="@Icons.Material.Filled.Home"
                        Size="@ButtonSize"
                        OnClick="@(() => Nav.NavigateTo(HomeHref))" />
            }

            @if (ShowBack)
            {
                <MudFab StartIcon="@Icons.Material.Filled.ArrowBackIosNew"
                        Size="@ButtonSize"
                        OnClick="BackClick" />
            }

            @if (ShowAdd)
            {
                <MudFab Color="Color.Tertiary"
                        StartIcon="@Icons.Material.Filled.Add"
                        Size="@ButtonSize"
                        OnClick="AddClick">
                    Adicionar
                </MudFab>
            }

            @if (ShowEdit)
            {
                <MudFab Color="Color.Secondary"
                        StartIcon="@Icons.Material.Filled.Edit"
                        Size="@ButtonSize"
                        OnClick="EditClick">
                    Editar
                </MudFab>
            }

            @if (ShowDelete)
            {
                <MudFab Color="Color.Error"
                        StartIcon="@Icons.Material.Filled.Delete"
                        Size="@ButtonSize"
                        OnClick="DeleteClick">
                    Excluir
                </MudFab>
            }

            @if (ChildContent is not null)
            {
                @ChildContent
            }

        </MudStack>

        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">

            @if (ShowSearch)
            {
                <MudTextField T="string"
                              @bind-Value="_searchText"
                              Placeholder="Pesquisar..."
                              Variant="Variant.Outlined"
                              Margin="MudBlazor.Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              Style="min-width:300px" />
            }

            @if (ShowSearchButton)
            {
                <MudFab StartIcon="@Icons.Material.Filled.Search"
                        Size="@ButtonSize"
                        Color="Color.Primary"
                        OnClick="SearchClick" />
            }

        </MudStack>

    </MudStack>

</MudPaper>

@code {
    private string? _searchText;

    [Parameter] public string Margin { get; set; } = "10px 0";
    [Parameter] public Size ButtonSize { get; set; } = Size.Small;

    [Parameter] public bool ShowHome { get; set; } = true;
    [Parameter] public bool ShowBack { get; set; } = true;
    [Parameter] public string HomeHref { get; set; } = "/";

    [Parameter] public bool ShowSearch { get; set; } = true;
    [Parameter] public bool ShowSearchButton { get; set; } = true;
    [Parameter] public EventCallback<string?> OnSearch { get; set; }

    [Parameter] public bool ShowAdd { get; set; }
    [Parameter] public bool ShowEdit { get; set; }
    [Parameter] public bool ShowDelete { get; set; }

    [Parameter] public EventCallback BackClick { get; set; }
    [Parameter] public EventCallback AddClick { get; set; }
    [Parameter] public EventCallback EditClick { get; set; }
    [Parameter] public EventCallback DeleteClick { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    private async Task SearchClick()
    {
        if (OnSearch.HasDelegate)
            await OnSearch.InvokeAsync(_searchText);
    }
}
